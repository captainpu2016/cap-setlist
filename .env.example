# ── Supabase ──────────────────────────────────────────────
# 在 Supabase Dashboard → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...（anon / public key）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...（service_role key，務必保密，不可外洩）

# ── 網站網址 ───────────────────────────────────────────────
# 本機開發用 http://localhost:3000
# 部署後改成正式網域，例如 https://setlist.normalcaptain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Spotify ───────────────────────────────────────────────
# 在 https://developer.spotify.com/dashboard 建立一個 App 取得
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
